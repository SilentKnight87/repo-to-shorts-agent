#!/bin/sh
set -e

msg_file="$1"

python3 - "$msg_file" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
text = path.read_text()
cleaned_lines = []
for line in text.splitlines():
    if line.lower().startswith("co-authored-by:"):
        continue
    cleaned_lines.append(line)
path.write_text("\n".join(cleaned_lines).rstrip() + "\n")
PY
